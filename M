def process_movie_description(message, movie_id, photo_id, title):
    try:
        description = message.text.strip()
        if not description:
            bot.send_message(message.chat.id, "❌ توضیحات نمی‌تواند خالی باشد.")
            return

        # چاپ مقادیر برای بررسی
        print(f"movie_id: {movie_id}, title: {title}, description: {description}, photo_id: {photo_id}")

        # ذخیره اطلاعات در دیتابیس
        cursor.execute(
            "INSERT INTO movies (movie_id, title, description, photo_id) VALUES (?, ?, ?, ?)",
            (movie_id, title, description, photo_id)
        )
        conn.commit()

        # ارسال به کانال عمومی
