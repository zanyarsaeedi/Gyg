    movie_data = cursor.execute(
        "SELECT title, trailer_file_id FROM movies WHERE movie_id = ?",
        (movie_id,)
    ).fetchone()

    if not movie_data:
        bot.send_message(message.chat.id, "❌ فیلمی برای ارسال یافت نشد.")
        return

    title, trailer_file_id = movie_data

