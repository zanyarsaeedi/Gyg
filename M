def add_column_if_not_exists():
    # بررسی وجود ستون در جدول
    cursor.execute("PRAGMA table_info(movies)")
    columns = [column[1] for column in cursor.fetchall()]  # استخراج نام ستون‌ها

    if "trailer_file_id" not in columns:
        cursor.execute("ALTER TABLE movies ADD COLUMN trailer_file_id TEXT")
        conn.commit()
        print("ستون trailer_file_id به جدول movies اضافه شد.")
    else:
        print("ستون trailer_file_id قبلاً وجود دارد.")

